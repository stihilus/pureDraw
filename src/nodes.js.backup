      ['ms', 'num', 'interval between bangs, in milliseconds (min 20)'],
    ],
    args: 'ms — interval in milliseconds (e.g. "metro 400")',
    out: 'bang — one every N ms',
  },
  until: {
    short: 'bang burst (the PD loop)',
    desc: 'The Pure Data way to loop: a bang fires N bangs in a row, immediately — one per iteration. Feed them into a counter to get an index (0, 1, 2…), and drive positions from that.',
    inlets: [
      ['trig', 'any', 'bang → fire N bangs / number → fire that many bangs'],
      ['n', 'num', 'set N, how many bangs one trig fires'],
    ],
    args: 'n — default number of bangs (e.g. "until 100")',
    out: 'bang — N of them, back to back',
  },
  counter: {
    short: 'counting bang',
    desc: 'Counter. Each bang sends the current count, then advances by step — wrapping back to min after max. Pair it with metro for loops: metro → counter 0 360 5 → sin gives a smooth wave.',
    inlets: [
      ['in', 'any', 'HOT — bang → send the count and advance / number → set the count, send it and advance'],
      ['set', 'any', 'COLD — bang → reset to min / number → jump to that value (no output)'],
    ],
    args: 'min max step (e.g. "counter 0 360 5")',
    out: 'num — the current count',
  },
  sin: {
    short: 'sine (degrees)',
    desc: 'Sine function. Takes an angle in DEGREES and sends sin(a) — a number between −1 and 1. Chain counter → sin → * amplitude → + offset for smooth wave motion.',
