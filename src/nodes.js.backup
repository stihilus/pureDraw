      ['y', 'num', 'center Y position'],
      ['w', 'num', 'width in px'],
      ['h', 'num', 'height in px'],
      ['fill', 'col', 'fill color (#hex or none)'],
      ['stroke', 'col', 'stroke color (#hex or none)'],
      ['sw', 'num', 'stroke width in px'],
    ],
    out: 'draw — draw signal',
  },
  circle: {
    short: 'circle',
    desc: 'Draws a circle. x,y is the CENTER.',
    inlets: [
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['r', 'num', 'radius in px'],
      ['fill', 'col', 'fill color (#hex or none)'],
      ['stroke', 'col', 'stroke color (#hex or none)'],
      ['sw', 'num', 'stroke width in px'],
    ],
    out: 'draw — draw signal',
  },
  line: {
    short: 'straight line',
    desc: 'Draws a straight line from point 1 to point 2.',
    inlets: [
      ['x1', 'num', 'start X'],
      ['y1', 'num', 'start Y'],
      ['x2', 'num', 'end X'],
      ['y2', 'num', 'end Y'],
      ['color', 'col', 'line color (#hex or none)'],
      ['w', 'num', 'line width in px'],
    ],
    out: 'draw — draw signal',
  },
  text: {
    short: 'draw text',
    desc: 'Draws text anchored at x,y. A "|" in the word breaks the line (multiline). Fonts: mono (Martian), plex, inter, grotesk, serif.',
    use: 'Connect a string node into word for multi-word text. Weight: 100–900 (needs to exist in the font). Align moves the anchor: left/center/right.',
    inlets: [
      ['word', 'str', 'the text to draw — "|" starts a new line'],
      ['x', 'num', 'anchor X position'],
      ['y', 'num', 'anchor Y position (centre of the line block)'],
      ['size', 'num', 'font size in px'],
      ['color', 'col', 'text color (#hex or none)'],
      ['font', 'str', 'mono / plex / inter / grotesk / serif'],
      ['weight', 'num', 'font weight 100–900'],
      ['align', 'str', 'left / center / right'],
      ['track', 'num', 'letter-spacing in px'],
    ],
    args: 'word x y size color font weight align track',
    out: 'draw — draw signal',
  },
  webcam: {
    short: 'live camera',
    desc: 'Draws the live camera image, mirrored like a selfie and cover-cropped to w × h, centered on x,y. The browser asks for camera permission on first use. Feed it into dither → duotone for a live riso mirror.',
    use: 'The canvas re-renders continuously (~30fps) while a webcam node exists in the patch.',
    inlets: [
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['w', 'num', 'width in px'],
      ['h', 'num', 'height in px'],
    ],
    args: 'x y w h',
    out: 'draw — the live camera as a draw signal',
  },
  feedback: {
    short: 'previous frame',
    desc: 'Outputs the PREVIOUS rendered frame as a draw source, placed centered on x,y at w × h. Route it through scale / rotate / alpha and put it UNDER your moving shapes: every frame repaints history — trails, tunnels, infinite zoom.',
    use: 'The canvas re-renders continuously (~30fps) while a feedback node exists. Classic recipe: feedback → scale 0.98 → alpha 0.95 → layer 1, moving shape → layer 2.',
    inlets: [
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['w', 'num', 'width in px'],
      ['h', 'num', 'height in px'],
    ],
    args: 'x y w h (defaults cover the whole canvas)',
    out: 'draw — last frame as a draw signal',
  },
  polygon: {
    short: 'regular polygon',
    desc: 'Draws a regular polygon with n sides, centered on x,y. rot spins it around its own center.',
    inlets: [
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['r', 'num', 'radius in px (center to corner)'],
      ['n', 'num', 'number of sides (3 = triangle, 6 = hexagon…)'],
      ['rot', 'num', 'rotation around its own center, degrees'],
      ['fill', 'col', 'fill color (#hex or none)'],
      ['stroke', 'col', 'stroke color (#hex or none)'],
      ['sw', 'num', 'stroke width in px'],
    ],
    out: 'draw — draw signal',
  },
  stamp: {
    short: 'stamp frozen copies',
    desc: 'Stamps frozen copies of its draw input. Every bang on the trig inlet captures the CURRENT state of the incoming shape and adds it to the pile — the outlet plays back all stamped copies. The classic pattern: until → counter moves a shape AND bangs the stamp → 100 copies along a curve. With metro it leaves trails.',
    use: 'Cables fire in the order they were made — connect the movement cables first and the trig cable last, so the shape moves before it is stamped.',
    inlets: [
      ['draw', 'draw', 'the shape(s) to copy'],
      ['trig', 'any', 'bang → stamp the current state of the input'],
      ['clear', 'any', 'anything → erase all stamps'],
    ],
    args: 'max — how many copies are kept, oldest dropped first (default 500)',
    out: 'draw — all stamped copies',
  },
  layer: {
    short: 'compositing layer',
    desc: 'A compositing layer, like in a design tool. The first argument is the layer NUMBER: layer 1 sits at the bottom of the canvas, higher numbers are drawn on top — no matter in which order the cables were connected. Within one layer, inlet 1 is at the bottom.',
    inlets: [
      ['d1…dn', 'draw', 'draw signals grouped into this layer (inlet 1 = bottom of the group)'],
    ],
    args: 'z count — layer number + number of inlets, 1–12 (e.g. "layer 2 6")',
    out: 'draw — the layer, connect it to the canvas',
  },
  canvas: {
    short: 'render output',
    desc: 'The output canvas — the sink of the patch (like dac~ in Pure Data). The draw inlet accepts MANY cables: everything arriving is stacked by the sender\'s layer number (layer 1 bottom, higher on top; non-layer senders count as layer 0) and rendered continuously.',
    use: 'The width and height become the variables w and h — usable in any numeric field as an expression: "rect w/2 h/2 w/4 h/4" centres a quarter-size rect. Supports + - * / % and ( ).',
    inlets: [
      ['draw', 'draw', 'draw signals to render — takes multiple cables, stacked by layer number'],
      ['w', 'num', 'canvas width in px — also the variable w'],
      ['h', 'num', 'canvas height in px — also the variable h'],
    ],
    out: '— (none)',
  },
