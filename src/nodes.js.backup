    desc: 'Toggle switch. Sends 1 when switched on (✕) and 0 when switched off.',
    use: 'Click the box to flip it (sends immediately). Drag the label strip to move the node.',
    inlets: [
      ['in', 'any', 'bang → flip and send / number → set on (≠0) or off (0) and send / "set N" → set without sending'],
    ],
    out: 'num — 1 or 0',
  },
  hslider: {
    short: 'horizontal slider',
    desc: 'Horizontal slider. Sends a number between min and max while you drag it.',
    use: 'Drag inside the track to send values. Drag the label strip to move the node.',
    inlets: [
      ['in', 'any', 'bang → send the current value / number → set the value and send it / "set N" → set without sending'],
