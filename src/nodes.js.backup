      ['a', 'num', 'angle in degrees → send sin(a) / bang → resend the last result'],
    ],
    out: 'num — sin(a), between −1 and 1',
  },
  cos: {
    short: 'cosine (degrees)',
    desc: 'Cosine function. Takes an angle in DEGREES and sends cos(a) — a number between −1 and 1. Use sin for x and cos for y (same angle) to move in a circle.',
