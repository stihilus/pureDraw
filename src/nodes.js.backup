  },
  random: {
    short: 'random number',
    desc: 'Random number generator. On any input, sends a whole number from 0 to max−1.',
    inlets: [
      ['trig', 'any', 'bang (or anything) → send a new random number'],
      ['max', 'num', 'upper limit (exclusive)'],
    ],
    args: 'max — upper limit (e.g. "random 800")',
    out: 'num — random whole number, 0…max−1',
  },
  '+': {
    short: 'add: a + b',
    desc: 'Adds two numbers: a + b. The LEFT inlet is hot (computes and sends), the RIGHT is cold (only stores).',
    inlets: [
      ['a', 'num', 'HOT — number → store it, compute and send / bang → recompute and send'],
      ['b', 'num', 'COLD — store the right operand'],
    ],
    args: 'b — right operand (e.g. "+ 10")',
    out: 'num — a + b',
  },
  '-': {
    short: 'subtract: a − b',
    desc: 'Subtracts: a − b. The LEFT inlet is hot (computes and sends), the RIGHT is cold (only stores).',
    inlets: [
      ['a', 'num', 'HOT — number → store it, compute and send / bang → recompute and send'],
      ['b', 'num', 'COLD — store the right operand'],
    ],
    args: 'b — right operand (e.g. "- 10")',
    out: 'num — a − b',
  },
  '*': {
    short: 'multiply: a × b',
    desc: 'Multiplies: a × b. The LEFT inlet is hot (computes and sends), the RIGHT is cold (only stores).',
    inlets: [
      ['a', 'num', 'HOT — number → store it, compute and send / bang → recompute and send'],
      ['b', 'num', 'COLD — store the right operand'],
    ],
    args: 'b — right operand (e.g. "* 2")',
    out: 'num — a × b',
  },
  '/': {
    short: 'divide: a ÷ b',
    desc: 'Divides: a ÷ b. The LEFT inlet is hot (computes and sends), the RIGHT is cold (only stores). Division by zero sends 0.',
    inlets: [
      ['a', 'num', 'HOT — number → store it, compute and send / bang → recompute and send'],
      ['b', 'num', 'COLD — store the right operand'],
    ],
    args: 'b — right operand (e.g. "/ 2")',
    out: 'num — a ÷ b',
  },
  loadbang: {
    short: 'bang on load',
    desc: 'Sends one bang the moment the patch is loaded — on app start, opening a demo, or loading a file. The PD way to make a patch start by itself: wire it wherever you would otherwise click a bng.',
    use: 'It fires only on load. A freshly added loadbang stays quiet until the patch is opened again (save it first, or reload).',
    inlets: [],
    out: 'bang — once, when the patch loads',
  },
  map: {
    short: 'remap a range',
    desc: 'Maps an incoming number from the range a…b to the range c…d. The classic slider adapter: "map 0 100 0 800" turns a 0–100 slider into canvas pixels. The output is NOT clamped — inputs outside a…b extrapolate.',
    inlets: [
      ['in', 'num', 'HOT — number → remap and send / bang → resend the last result'],
      ['a', 'num', 'COLD — input range start'],
      ['b', 'num', 'COLD — input range end'],
      ['c', 'num', 'COLD — output range start'],
      ['d', 'num', 'COLD — output range end'],
    ],
    args: 'a b c d (e.g. "map 0 100 20 90")',
    out: 'num — the remapped value',
  },
  comment: {
    short: 'patch annotation',
    desc: 'A text note that lives in the patch. No inlets, no outlets, no effect on the canvas — it only explains the patch to whoever reads it next.',
    use: 'Type "comment your text here". Double-click to edit, drag to move, Delete to remove.',
    inlets: [],
    out: '— (none)',
  },
  alpha: {
    short: 'transparency',
    desc: 'Sets the opacity of everything passing through it: 1 = solid, 0 = invisible. Nested alphas multiply.',
    inlets: [
      ['draw', 'draw', 'the shapes to make transparent'],
      ['a', 'num', 'opacity, 0…1'],
    ],
    args: 'a — opacity 0…1 (e.g. "alpha 0.5")',
    out: 'draw — the transparent draw signal',
  },
  blend: {
    short: 'blend mode',
    desc: 'Sets the blend mode of everything passing through it — how it mixes with what is already drawn below. Put it BETWEEN a layer and the canvas ("layer 2 → blend multiply → canvas") and it applies to that layer only. Modes: normal, multiply, screen, overlay, darken, lighten, difference, exclusion.',
    inlets: [
      ['draw', 'draw', 'the shapes to blend'],
      ['mode', 'str', 'blend mode name (connect a string node to change it live)'],
    ],
    args: 'mode (e.g. "blend difference")',
    out: 'draw — the blended draw signal',
  },
  tile: {
    short: 'repeat in a grid',
    desc: 'Repeats everything passing through it in an nx × ny grid, stepping dx px right and dy px down. What stamp does over time, tile does in space — patterns from a single shape, no loop needed.',
    inlets: [
      ['draw', 'draw', 'the shapes to repeat'],
      ['nx', 'num', 'columns'],
      ['ny', 'num', 'rows'],
      ['dx', 'num', 'horizontal step in px'],
      ['dy', 'num', 'vertical step in px'],
    ],
    args: 'nx ny dx dy (e.g. "tile 4 4 200 200")',
    out: 'draw — the tiled draw signal',
  },
  mirror: {
    short: 'mirror + original',
    desc: 'Outputs everything passing through it PLUS its mirror image across an axis: "mirror x 400" reflects across the vertical line x=400, "mirror y 400" across the horizontal line y=400. Chain two mirrors (x then y) for four-fold kaleidoscope symmetry.',
    inlets: [
      ['draw', 'draw', 'the shapes to mirror'],
      ['axis', 'str', '"x" (vertical mirror line) or "y" (horizontal mirror line)'],
      ['pos', 'num', 'position of the mirror line in px'],
    ],
    args: 'axis pos (e.g. "mirror x 400")',
    out: 'draw — original + reflected copy',
  },
  image: {
    short: 'image from URL',
    desc: 'Draws an image loaded from a URL, centered on x,y. Set w or h to 0 to use the image\'s natural size. The URL must allow cross-origin use (CORS), or the browser will refuse to load it — e.g. picsum.photos works.',
    use: 'The canvas re-renders automatically when the image finishes loading.',
    inlets: [
      ['url', 'str', 'image URL (no spaces — connect a string node for longer ones)'],
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['w', 'num', 'width in px (0 = natural)'],
      ['h', 'num', 'height in px (0 = natural)'],
    ],
    args: 'url x y w h',
    out: 'draw — draw signal',
  },
  clamp: {
    short: 'limit to a range',
    desc: 'Clamps an incoming number into the range a…b: values below a become a, values above b become b, everything else passes unchanged. The seatbelt for noise, mouse and math chains.',
    inlets: [
      ['in', 'num', 'HOT — number → clamp and send / bang → resend the last result'],
      ['a', 'num', 'COLD — lower bound'],
      ['b', 'num', 'COLD — upper bound'],
    ],
    args: 'a b (e.g. "clamp 0 800")',
    out: 'num — the clamped value',
  },
  change: {
    short: 'only pass changes',
    desc: 'Passes a message on only when it DIFFERS from the previous one; repeats are dropped. Put it behind mouse or noise to thin out floods of identical values.',
    inlets: [
      ['in', 'any', 'value → pass it only if it changed / bang → resend the last value'],
    ],
    out: 'any — the value, once per change',
  },
  hsl: {
    short: 'color from numbers',
    desc: 'Builds a hex color string from three numbers — hue 0–360, saturation 0–100, lightness 0–100 — and sends it into any color inlet. This is animated color: counter → hsl → fill is a hue rotation, noise → the l inlet makes a color breathe.',
    inlets: [
      ['h', 'num', 'HOT — hue in degrees (wraps around 360) → compute and send / bang → resend'],
      ['s', 'num', 'COLD — saturation 0–100'],
      ['l', 'num', 'COLD — lightness 0–100'],
    ],
    args: 'h s l (e.g. "hsl 200 80 60")',
    out: 'str — a "#rrggbb" color',
  },
  time: {
    short: 'clock (h m s)',
    desc: 'On any input, sends the current time of day through three outlets: hours (0–23), minutes and seconds. metro 1000 → time → * 6 → rotate is a working clock hand.',
    inlets: [
      ['in', 'any', 'bang (or anything) → send the current time'],
    ],
    outs: [
      ['h', 'num', 'hours, 0–23'],
      ['m', 'num', 'minutes, 0–59'],
      ['s', 'num', 'seconds, 0–59'],
    ],
    out: 'h, m, s (right outlet fires first)',
  },
  ramp: {
    short: 'glide to a value',
    desc: 'The PD [line]: when a number arrives, ramp does not jump — it GLIDES from its current value to the target over N milliseconds, sending intermediate values along the way. Put it in front of any position/size inlet and jumps become motion.',
    inlets: [
      ['in', 'any', 'number → glide to it / bang → resend the current value'],
      ['ms', 'num', 'set the glide time for the next ramps'],
    ],
    args: 'ms — glide duration in milliseconds (e.g. "ramp 600")',
    out: 'num — a stream of values from here to the target',
  },
  noise: {
    short: 'smooth noise',
    desc: 'Smooth 1D noise: feed it a running number (counter, time) and it returns an organic wander between −1 and 1. What random does nervously, noise does naturally — drift, wobble, hand-drawn feel. Same input always gives the same output.',
    use: 'Add an offset to the input (e.g. + 5000) to get a second, independent noise stream from the same counter.',
    inlets: [
      ['in', 'num', 'position/time → send noise(in × f) / bang → resend'],
      ['f', 'num', 'frequency — smaller = smoother (default 0.05)'],
    ],
    args: 'f — frequency (e.g. "noise 0.02")',
    out: 'num — smooth noise, −1…1',
  },
  key: {
    short: 'keyboard input',
    desc: 'Sends the name of every key pressed — "a", "5", "ArrowLeft", " "… Feed it into sel to react to specific keys: key → sel r → bang when R is pressed.',
    use: 'Keys typed while editing a node or a value box are ignored.',
    inlets: [],
    out: 'str — the key name, on every press',
  },
  send: {
    short: 'wireless out',
    desc: 'Sends every incoming message to ALL receive nodes with the same name — no cable needed. The PD way to keep big patches readable: control messages travel by name, only draw signals need cables.',
    inlets: [
      ['in', 'any', 'any message → deliver it to every matching receive'],
    ],
    args: 'name — the channel (e.g. "send tick")',
    out: '— (none — the matching receive nodes output instead)',
  },
  receive: {
    short: 'wireless in',
    desc: 'Outputs everything that a send node with the same name receives, anywhere in the patch. Many receives can listen to one send, and many sends can feed one receive.',
    inlets: [],
    args: 'name — the channel (e.g. "receive tick")',
    out: 'any — whatever the matching send got',
  },
  gradient: {
    short: 'linear gradient fill',
    desc: 'Fills the whole canvas with a linear gradient running from point 1 to point 2, blending color c1 into c2. A bg with direction — put it in the bottom layer. Feed the color inlets from hsl for a living background.',
    inlets: [
      ['x1', 'num', 'gradient start X'],
      ['y1', 'num', 'gradient start Y'],
      ['x2', 'num', 'gradient end X'],
      ['y2', 'num', 'gradient end Y'],
      ['c1', 'col', 'start color (#hex)'],
      ['c2', 'col', 'end color (#hex)'],
    ],
    args: 'x1 y1 x2 y2 c1 c2 (e.g. "gradient 0 0 800 800 #000000 #ffffff")',
    out: 'draw — draw signal',
  },
  clip: {
    short: 'mask (clip to a shape)',
    desc: 'Clips its draw input to the silhouette of the mask input: whatever arrives at the mask inlet (rect, circle, ellipse, polygon — also tiled, mirrored or transformed) becomes a stencil, and the content is only visible inside it. Image in a circle, pattern inside a letterform-sized rect, texture inside a polygon.',
    use: 'Lines, text and images are ignored as masks — use the solid shapes. Several shapes in the mask make a combined stencil.',
    inlets: [
      ['draw', 'draw', 'the content to be clipped'],
      ['mask', 'draw', 'the shape(s) that define where content is visible'],
    ],
    out: 'draw — the clipped content',
  },
  dash: {
    short: 'dashed strokes',
    desc: 'Makes every stroke passing through it dashed: a px of line, then b px of gap. Fills are unaffected. Blueprint and map aesthetics in one node.',
    inlets: [
      ['draw', 'draw', 'the shapes whose strokes become dashed'],
      ['a', 'num', 'dash length in px'],
      ['b', 'num', 'gap length in px'],
    ],
    args: 'a b (e.g. "dash 6 10")',
    out: 'draw — the dashed draw signal',
  },
  '>': {
    short: 'greater than → 1|0',
    desc: 'Comparison: sends 1 if a > b, else 0. Feed the result into a spigot (as a gate) or a sel to trigger conditional behaviour — "if x > 400, do this". Left inlet is hot, right is cold.',
    inlets: [
      ['a', 'num', 'HOT — number → compare and send / bang → resend'],
      ['b', 'num', 'COLD — the value to compare against'],
    ],
    args: 'b — right operand (e.g. "> 400")',
    out: 'num — 1 if a > b, else 0',
  },
  '<': {
    short: 'less than → 1|0',
    desc: 'Comparison: sends 1 if a < b, else 0. Left inlet is hot, right is cold.',
    inlets: [
      ['a', 'num', 'HOT — number → compare and send / bang → resend'],
      ['b', 'num', 'COLD — the value to compare against'],
    ],
    args: 'b — right operand (e.g. "< 100")',
    out: 'num — 1 if a < b, else 0',
  },
  '==': {
    short: 'equal → 1|0',
    desc: 'Comparison: sends 1 if a equals b, else 0. Great after a counter: "== 0" fires only on the first step. Left inlet is hot, right is cold.',
    inlets: [
      ['a', 'num', 'HOT — number → compare and send / bang → resend'],
      ['b', 'num', 'COLD — the value to compare against'],
    ],
    args: 'b — right operand (e.g. "== 0")',
    out: 'num — 1 if a == b, else 0',
  },
  '>=': {
    short: 'greater-or-equal → 1|0',
    desc: 'Comparison: sends 1 if a ≥ b, else 0. Left inlet is hot, right is cold.',
    inlets: [
      ['a', 'num', 'HOT — number → compare and send / bang → resend'],
      ['b', 'num', 'COLD — the value to compare against'],
    ],
    args: 'b — right operand (e.g. ">= 128")',
    out: 'num — 1 if a ≥ b, else 0',
  },
  moses: {
    short: 'split at a threshold',
    desc: 'Routes a number by a threshold (PD classic): values BELOW thr come out the left outlet, values AT-OR-ABOVE come out the right — both unchanged. Fork a stream into two paths with one node.',
    inlets: [
      ['in', 'num', 'the number to route'],
      ['thr', 'num', 'threshold (cold)'],
    ],
    args: 'thr — threshold (e.g. "moses 400")',
    outs: [
      ['< thr', 'num', 'values below the threshold'],
      ['≥ thr', 'num', 'values at or above the threshold'],
    ],
    out: 'below → left, at-or-above → right',
  },
  threshold: {
    short: 'black & white cutoff',
    desc: 'A pixel effect: rasterises everything passing through it, then forces each pixel to pure black or white — bright pixels (luminance ≥ level) turn white, the rest black. High-contrast, stencil look. Put it after a layer to threshold the whole thing.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to threshold'],
      ['level', 'num', 'cutoff brightness, 0–255 (higher = more black)'],
    ],
    args: 'level — cutoff 0–255 (e.g. "threshold 128")',
    out: 'draw — black & white draw signal',
  },
  posterize: {
    short: 'reduce colour steps',
    desc: 'A pixel effect: quantises each colour channel to a small number of levels, flattening smooth gradients into bands. Keeps hue, kills subtlety — screenprint / risograph feel.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to posterise'],
      ['levels', 'num', 'steps per channel, 2–64 (fewer = flatter)'],
    ],
    args: 'levels — steps per channel (e.g. "posterize 4")',
    out: 'draw — posterised draw signal',
  },
  dither: {
    short: 'ordered dither',
    desc: 'A pixel effect: converts to black & white using an ordered (Bayer) dither, so shades become patterns of dots instead of solid grey. Classic 1-bit / newsprint look. scale makes the dots chunkier; levels adds grey steps.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to dither'],
      ['scale', 'num', 'dot size in px, 1+ (bigger = chunkier)'],
      ['levels', 'num', 'output shades, 2–8 (2 = pure b&w)'],
    ],
    args: 'scale levels (e.g. "dither 2 2")',
    out: 'draw — dithered draw signal',
  },
  pixelate: {
    short: 'mosaic / low-res',
    desc: 'A pixel effect: averages the image into square blocks, giving a chunky low-resolution mosaic. Pairs with threshold and dither for a lo-fi, retro feel.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to pixelate'],
      ['size', 'num', 'block size in px (bigger = blockier)'],
    ],
    args: 'size — block size in px (e.g. "pixelate 12")',
    out: 'draw — pixelated draw signal',
  },
  duotone: {
    short: 'two-colour map',
    desc: 'A pixel effect: maps brightness onto a two-colour ramp — dark pixels become the dark colour, bright pixels the light colour, midtones blend between. Feed dither into duotone for the signature riso / newsprint-in-colour look.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to map'],
      ['dark', 'col', 'colour for the shadows (#hex)'],
      ['light', 'col', 'colour for the highlights (#hex)'],
    ],
    args: 'dark light (e.g. "duotone #1a1a40 #ff5050")',
    out: 'draw — duotone draw signal',
  },
  blur: {
    short: 'gaussian blur',
    desc: 'A filter effect: composites everything passing through it, then blurs the whole thing by radius px. Soft glows, depth, out-of-focus layers.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to blur'],
      ['radius', 'num', 'blur radius in px'],
    ],
    args: 'radius — blur radius in px (e.g. "blur 8")',
    out: 'draw — blurred draw signal',
  },
  invert: {
    short: 'invert colours',
    desc: 'A filter effect: inverts the colours of everything passing through it (black ↔ white, and every hue to its opposite).',
    inlets: [['draw', 'draw', 'the shapes/image to invert']],
    out: 'draw — inverted draw signal',
  },
  grayscale: {
    short: 'desaturate',
    desc: 'A filter effect: removes all colour, leaving luminance only.',
    inlets: [['draw', 'draw', 'the shapes/image to desaturate']],
    out: 'draw — grayscale draw signal',
  },
  contrast: {
    short: 'adjust contrast',
    desc: 'A filter effect: scales contrast — 1 = unchanged, >1 punchier, <1 flatter, 0 = solid grey.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to adjust'],
      ['amount', 'num', 'contrast factor (1 = normal)'],
    ],
    args: 'amount — contrast factor (e.g. "contrast 1.8")',
    out: 'draw — contrast-adjusted draw signal',
  },
  brightness: {
    short: 'adjust brightness',
    desc: 'A filter effect: scales brightness — 1 = unchanged, >1 brighter, <1 darker, 0 = black.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to adjust'],
      ['amount', 'num', 'brightness factor (1 = normal)'],
    ],
    args: 'amount — brightness factor (e.g. "brightness 1.4")',
    out: 'draw — brightness-adjusted draw signal',
  },
  hue: {
    short: 'rotate hue',
    desc: 'A filter effect: rotates every colour around the hue wheel by deg degrees. Drive it from a counter for a colour cycle over the whole layer.',
    inlets: [
      ['draw', 'draw', 'the shapes/image to shift'],
      ['deg', 'num', 'hue rotation in degrees'],
    ],
    args: 'deg — hue rotation in degrees (e.g. "hue 120")',
    out: 'draw — hue-shifted draw signal',
  },
  shadow: {
    short: 'drop shadow',
    desc: 'Adds a drop shadow to everything passing through it: blur radius, offset dx/dy and color. Cheap depth for posters and UI mockups.',
    inlets: [
      ['draw', 'draw', 'the shapes to shade'],
      ['blur', 'num', 'shadow blur radius in px'],
      ['dx', 'num', 'shadow offset X'],
      ['dy', 'num', 'shadow offset Y'],
      ['color', 'col', 'shadow color (#hex or none)'],
    ],
    args: 'blur dx dy color (e.g. "shadow 40 0 24 #000000")',
    out: 'draw — the shaded draw signal',
  },
  ellipse: {
    short: 'ellipse',
    desc: 'Draws an ellipse, centered on x,y, with full width w and height h (like rect, unlike circle\'s radius).',
    inlets: [
      ['x', 'num', 'center X position'],
      ['y', 'num', 'center Y position'],
      ['w', 'num', 'full width in px'],
      ['h', 'num', 'full height in px'],
      ['fill', 'col', 'fill color (#hex or none)'],
      ['stroke', 'col', 'stroke color (#hex or none)'],
      ['sw', 'num', 'stroke width in px'],
    ],
    out: 'draw — draw signal',
  },
  t: {
    short: 'order control (trigger)',
    desc: 'Trigger. One message in, fired out through one outlet per argument, RIGHT to LEFT: "v" passes the incoming value on, "b" sends a bang. This is the PD way to make message order explicit instead of relying on cable creation order — e.g. "t b b" into stamp: right outlet clears first, left outlet runs the loop.',
    inlets: [
      ['in', 'any', 'any message → fire all outlets, rightmost first'],
    ],
    args: 'a sequence of v / b, one outlet each (e.g. "t b v"); no args = "t v v"',
    outs: [
      ['1…n', 'any', 'per argument: v passes the value, b sends a bang — RIGHT outlet fires FIRST'],
    ],
    out: 'one outlet per argument',
  },
  sel: {
    short: 'match → bang (select)',
    desc: 'Select. Compares every incoming value with its arguments: on a match, that argument\'s outlet sends a bang; everything else falls out of the RIGHTMOST outlet unchanged. With a counter in front it becomes a step sequencer: "on step 3, do this".',
    use: 'One outlet per argument, plus the pass-through outlet on the far right. Arguments can be numbers or words.',
    inlets: [
      ['in', 'any', 'the value to test against the arguments'],
      ['set', 'any', 'only when there is a single argument — sets the match value'],
    ],
    args: 'one or more values to match (e.g. "sel 0 4 8" or "sel GO")',
    outs: [
      ['match', 'bang', 'one outlet per argument — bangs when the input equals it'],
      ['rest', 'any', 'rightmost — passes every non-matching input through'],
    ],
    out: 'bang per match + pass-through',
  },
  spigot: {
    short: 'message gate',
    desc: 'A gate for messages. While open, everything arriving at the left inlet passes through unchanged; while closed, it is dropped. Control it with a toggle — or with the btn outlet of mouse for press-and-drag behaviour.',
    inlets: [
      ['in', 'any', 'HOT — passes through when the gate is open'],
      ['open', 'num', 'COLD — 1 opens the gate, 0 closes it'],
    ],
    args: 'open — initial state, 1 or 0 (e.g. "spigot 1")',
    out: 'any — whatever passed the gate',
  },
  pipe: {
    short: 'delay messages',
    desc: 'Delays every message by N milliseconds, then sends it on unchanged. Chain several pipes for step sequences.',
    inlets: [
      ['in', 'any', 'message → send it on after the delay'],
      ['ms', 'num', 'set the delay time in milliseconds'],
    ],
    args: 'ms — delay in milliseconds (e.g. "pipe 1000")',
    out: 'any — the delayed message',
  },
  mouse: {
    short: 'cursor input',
    desc: 'The mouse over the PREVIEW canvas, in canvas coordinates. Streams x and y while the cursor moves; the btn outlet sends 1 on press and 0 on release. mouse → circle x/y + btn → spigot gating a metro that bangs a stamp = freehand drawing.',
    inlets: [],
    outs: [
      ['x', 'num', 'cursor X in canvas px, streams while moving'],
      ['y', 'num', 'cursor Y in canvas px, streams while moving'],
      ['btn', 'num', '1 when the button goes down, 0 when it goes up'],
    ],
    out: 'x, y, btn',
  },
  rotate: {
    short: 'rotate draw signal',
    desc: 'Rotates everything passing through it by deg degrees around the pivot cx,cy. Transforms stack freely: shape → rotate → scale → layer. Drive deg from until + counter and stamp each step for radial patterns and mandalas.',
    inlets: [
      ['draw', 'draw', 'the shapes to rotate'],
      ['deg', 'num', 'angle in degrees'],
      ['cx', 'num', 'pivot X'],
      ['cy', 'num', 'pivot Y'],
    ],
    args: 'deg cx cy (e.g. "rotate 45 400 400")',
    out: 'draw — the rotated draw signal',
  },
  scale: {
    short: 'scale draw signal',
    desc: 'Scales everything passing through it by the factor s around the pivot cx,cy (1 = unchanged, 2 = double, 0.5 = half).',
    inlets: [
      ['draw', 'draw', 'the shapes to scale'],
      ['s', 'num', 'scale factor'],
      ['cx', 'num', 'pivot X'],
      ['cy', 'num', 'pivot Y'],
    ],
    args: 's cx cy (e.g. "scale 1.5 400 400")',
    out: 'draw — the scaled draw signal',
  },
  translate: {
    short: 'move draw signal',
    desc: 'Shifts everything passing through it by dx,dy pixels.',
