    out: 'num — the current value',
  },
  vslider: {
    short: 'vertical slider',
    desc: 'Vertical slider. Sends a number between min (bottom) and max (top) while you drag it.',
    use: 'Drag inside the track to send values. Drag the label strip to move the node.',
