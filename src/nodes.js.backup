// node type definitions + text parsing
// args: [name, type, default]  — every arg is also an inlet (typed value = fallback until a message arrives)

// the bang message — PD-style: the literal word "bang"
export const BANG = 'bang';

export const TYPES = {
  // gui / value nodes (one control inlet, one outlet) — they SEND messages
  bng:     { gui: true, out: 'bang' },
  number:  { gui: true, out: 'num' },
  string:  { gui: true, out: 'str' },
  toggle:  { gui: true, out: 'num' },
  hslider: { gui: true, out: 'num', args: [['min','num',0], ['max','num',100]] },
  vslider: { gui: true, out: 'num', args: [['min','num',0], ['max','num',100]] },

  // control nodes — message in, message out
  loadbang: { out: 'bang', loadbang: true },
  metro:   { out: 'bang', metro: true, args: [['ms','num',500]] },
  until:   { out: 'bang', until: true, args: [['n','num',10]] },
  counter: { out: 'num',  counter: true, args: [['min','num',0], ['max','num',100], ['step','num',1]] },
  random:  { out: 'num',  rand: true,  args: [['max','num',100]] },
  sin:     { out: 'num',  fn: true },
  cos:     { out: 'num',  fn: true },
  '+':    { out: 'num',  math: true,  args: [['b','num',0]] },
  '-':    { out: 'num',  math: true,  args: [['b','num',0]] },
  '*':    { out: 'num',  math: true,  args: [['b','num',1]] },
  '/':    { out: 'num',  math: true,  args: [['b','num',1]] },
  '>':    { out: 'num',  compare: true, args: [['b','num',0]] },
  '<':    { out: 'num',  compare: true, args: [['b','num',0]] },
  '==':   { out: 'num',  compare: true, args: [['b','num',0]] },
  '>=':   { out: 'num',  compare: true, args: [['b','num',0]] },
  moses:  { out: 'multi', moses: true, args: [['thr','num',0]] },
  map:    { out: 'num',  map: true, args: [['a','num',0],['b','num',100],['c','num',0],['d','num',800]] },
  clamp:  { out: 'num',  clamp: true, args: [['a','num',0],['b','num',100]] },
  change: { out: 'ctl',  change: true },
  hsl:    { out: 'str',  hsl: true, args: [['h','num',0],['s','num',100],['l','num',50]] },
  time:   { out: 'multi', time: true },
  ramp:   { out: 'num',  ramp: true, args: [['ms','num',500]] },
  noise:  { out: 'num',  noise: true, args: [['f','num',0.05]] },
  t:      { out: 'multi', trigger: true },
  sel:    { out: 'multi', sel: true },

  // keyboard input + wireless connections
  key:     { out: 'str', key: true },
  send:    { out: null,  send: true },
  receive: { out: 'ctl', recv: true },
  spigot: { out: 'ctl',  spigot: true, args: [['open','num',0]] },
  pipe:   { out: 'ctl',  pipe: true,   args: [['ms','num',500]] },
  mouse:  { out: 'multi', mouse: true },

  // draw nodes (outlet type: draw — a continuous signal, like ~ in PD)
  bg:     { out: 'draw', args: [['color','col','#000000']] },
  gradient: { out: 'draw', args: [['x1','num',0],['y1','num',0],['x2','num',800],['y2','num',800],['c1','col','#000000'],['c2','col','#ffffff']] },
  rect:   { out: 'draw', args: [['x','num',400],['y','num',400],['w','num',200],['h','num',200],['fill','col','#000000'],['stroke','col','none'],['sw','num',0]] },
  circle: { out: 'draw', args: [['x','num',400],['y','num',400],['r','num',100],['fill','col','#000000'],['stroke','col','none'],['sw','num',0]] },
  line:   { out: 'draw', args: [['x1','num',100],['y1','num',100],['x2','num',700],['y2','num',700],['color','col','#000000'],['w','num',2]] },
  text:   { out: 'draw', args: [['word','str','TEXT'],['x','num',400],['y','num',400],['size','num',48],['color','col','#000000'],['font','str','mono'],['weight','num',400],['align','str','center'],['track','num',0]] },

  polygon: { out: 'draw', args: [['x','num',400],['y','num',400],['r','num',100],['n','num',6],['rot','num',0],['fill','col','#000000'],['stroke','col','none'],['sw','num',0]] },
  ellipse: { out: 'draw', args: [['x','num',400],['y','num',400],['w','num',300],['h','num',200],['fill','col','#000000'],['stroke','col','none'],['sw','num',0]] },
  image:   { out: 'draw', args: [['url','str',''],['x','num',400],['y','num',400],['w','num',300],['h','num',300]] },
  webcam:  { out: 'draw', args: [['x','num',400],['y','num',400],['w','num',800],['h','num',600]] },

  // the previous rendered frame as a draw source — trails, tunnels, video feedback
  feedback: { out: 'draw', args: [['x','num',400],['y','num',400],['w','num',800],['h','num',800]] },

  // stamps frozen copies of its draw input on every trig bang
  stamp:  { out: 'draw', stamp: true, args: [['max','num',500]] },

  // transforms: the draw signal passes through and everything inside is transformed
  rotate:    { out: 'draw', xform: true, args: [['deg','num',0],['cx','num',400],['cy','num',400]] },
  scale:     { out: 'draw', xform: true, args: [['s','num',1],['cx','num',400],['cy','num',400]] },
  translate: { out: 'draw', xform: true, args: [['dx','num',0],['dy','num',0]] },
  alpha:     { out: 'draw', xform: true, args: [['a','num',1]] },
  blend:     { out: 'draw', xform: true, args: [['mode','str','multiply']] },
  shadow:    { out: 'draw', xform: true, args: [['blur','num',20],['dx','num',0],['dy','num',10],['color','col','#000000']] },
  tile:      { out: 'draw', xform: true, args: [['nx','num',3],['ny','num',3],['dx','num',100],['dy','num',100]] },
  mirror:    { out: 'draw', xform: true, args: [['axis','str','x'],['pos','num',400]] },
  dash:      { out: 'draw', xform: true, args: [['a','num',8],['b','num',8]] },
  rectMode:  { out: 'draw', mode: true, args: [['mode','str','corner']] },
  ellipseMode: { out: 'draw', mode: true, args: [['mode','str','corner']] },

  // pixel effects: rasterise the incoming draw signal, then process its pixels
  threshold: { out: 'draw', xform: true, pixel: true, args: [['level','num',128]] },
  posterize: { out: 'draw', xform: true, pixel: true, args: [['levels','num',4]] },
  dither:    { out: 'draw', xform: true, pixel: true, args: [['scale','num',2],['levels','num',2]] },
  pixelate:  { out: 'draw', xform: true, pixel: true, args: [['size','num',8]] },
  duotone:   { out: 'draw', xform: true, pixel: true, args: [['dark','col','#1a1a40'],['light','col','#ff5050']] },

  // filter effects: composite the draw signal, then apply a canvas filter to it
  blur:       { out: 'draw', xform: true, filter: true, args: [['radius','num',4]] },
  invert:     { out: 'draw', xform: true, filter: true },
  grayscale:  { out: 'draw', xform: true, filter: true },
  contrast:   { out: 'draw', xform: true, filter: true, args: [['amount','num',1.5]] },
  brightness: { out: 'draw', xform: true, filter: true, args: [['amount','num',1.3]] },
  hue:        { out: 'draw', xform: true, filter: true, args: [['deg','num',90]] },

  // clips its draw input to the silhouette of the mask input
  clip:   { out: 'draw', clip: true },

  // patch annotation — no ports, no output
  comment: { comment: true, out: null },

  // compositing layer: z = stacking order at the canvas (1 = bottom), count = inlets
  layer:  { out: 'draw', layer: true, args: [['z','num',1], ['count','num',4]] },

  // sink (like dac~)
  canvas: { out: null, sink: true, args: [['w','num',800],['h','num',800]] },
};

const COLOR_RE = /^#([0-9a-fA-F]{3}|[0-9a-fA-F]{4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$/;

export function clamp(v, a, b) { return Math.min(b, Math.max(a, v)); }

// global variables usable in numeric fields — bound to the canvas size each frame.
// w = canvas width, h = canvas height. Extend here to add more.
export const VARS = { w: 800, h: 800 };

// tiny safe expression evaluator: numbers, variables (w, h), + - * / % and ( ).
// returns NaN on any parse error. Powers "w/2", "h/8", "w*0.25" in numeric fields.
export function evalExpr(src, vars = VARS) {
  const s = String(src);
  let i = 0;
  const skip = () => { while (i < s.length && s[i] === ' ') i++; };
  function parseExpr() {
    let v = parseTerm();
    skip();
    while (s[i] === '+' || s[i] === '-') {
      const op = s[i++]; const r = parseTerm(); skip();
      v = op === '+' ? v + r : v - r;
    }
    return v;
  }
  function parseTerm() {
    let v = parseFactor();
    skip();
    while (s[i] === '*' || s[i] === '/' || s[i] === '%') {
      const op = s[i++]; const r = parseFactor(); skip();
      v = op === '*' ? v * r : op === '/' ? (r === 0 ? 0 : v / r) : (r === 0 ? 0 : v % r);
    }
    return v;
  }
  function parseFactor() {
    skip();
    if (s[i] === '+') { i++; return parseFactor(); }
    if (s[i] === '-') { i++; return -parseFactor(); }
    if (s[i] === '(') {
      i++; const v = parseExpr(); skip();
      if (s[i] === ')') i++; else return NaN;
      return v;
    }
    // number
    const m = /^[0-9]*\.?[0-9]+/.exec(s.slice(i));
    if (m) { i += m[0].length; return parseFloat(m[0]); }
    // identifier (variable)
    const id = /^[a-zA-Z_][a-zA-Z0-9_]*/.exec(s.slice(i));
    if (id) {
      i += id[0].length;
      return id[0] in vars ? vars[id[0]] : NaN;
    }
    return NaN;
  }
  const result = parseExpr();
  skip();
  return i === s.length ? result : NaN; // trailing junk → invalid
}

export function coerceNum(v, d = 0) {
  if (typeof v === 'number') return isFinite(v) ? v : d;
  if (v == null) return d;
  const s = String(v);
  // fast path: a plain number, no variables or operators
  if (/^\s*-?[0-9]*\.?[0-9]+\s*$/.test(s)) return parseFloat(s);
  // expression path (w/2, h*0.5, (w-100)/2 …)
  const n = evalExpr(s);
  return isFinite(n) ? n : d;
}
export function coerceStr(v, d = '') {
  return v == null ? d : String(v);
}
export function coerceCol(v, d = '#000000') {
  const s = String(v ?? '').trim();
  if (s === 'none' || COLOR_RE.test(s)) return s;
  return d;
}
export function coerce(type, v, d) {
  if (type === 'num') return coerceNum(v, d);
  if (type === 'col') return coerceCol(v, d);
  return coerceStr(v, d);
}

// parse node text -> {type, tokens}
export function parseText(text) {
  const tokens = text.trim().split(/\s+/).filter(Boolean);
  return { type: tokens[0] || '', tokens };
}

// raw typed value of arg i (undefined if not typed)
export function argRaw(node, i) {
  return node.tokens ? node.tokens[i + 1] : undefined;
}

// resolved typed value of arg i (typed token or default)
export function argVal(node, i) {
  const def = TYPES[node.type];
  if (!def || !def.args || !def.args[i]) return undefined;
  const [, type, dflt] = def.args[i];
  const raw = argRaw(node, i);
  return raw === undefined ? dflt : coerce(type, raw, dflt);
}

// inlet spec list for a node: [{name, type, arg}] — arg = index into args used as fallback
export function inletsOf(node) {
  const def = TYPES[node.type];
  if (!def) return [];
  if (def.gui) return [{ name: 'in', type: 'ctl' }];
  if (def.loadbang) return [];
  if (def.metro)   return [{ name: 'on', type: 'ctl' }, { name: 'ms', type: 'num', arg: 0 }];
  if (def.until)   return [{ name: 'trig', type: 'ctl' }, { name: 'n', type: 'num', arg: 0 }];
  if (def.stamp)   return [{ name: 'draw', type: 'draw' }, { name: 'trig', type: 'ctl' }, { name: 'clear', type: 'ctl' }];
  if (def.counter) return [{ name: 'in', type: 'ctl' }, { name: 'set', type: 'ctl' }];
  if (def.rand)    return [{ name: 'trig', type: 'ctl' }, { name: 'max', type: 'num', arg: 0 }];
  if (def.fn)      return [{ name: 'a', type: 'num' }];
  if (def.math)    return [{ name: 'a', type: 'num' }, { name: 'b', type: 'num', arg: 0 }];
  if (def.compare) return [{ name: 'a', type: 'num' }, { name: 'b', type: 'num', arg: 0 }];
  if (def.moses)   return [{ name: 'in', type: 'num' }, { name: 'thr', type: 'num', arg: 0 }];
  if (def.trigger) return [{ name: 'in', type: 'ctl' }];
  if (def.sel) {
    // PD: a single-argument sel gets a right inlet to change the match value
    return selArgs(node).length === 1
      ? [{ name: 'in', type: 'ctl' }, { name: 'set', type: 'ctl' }]
      : [{ name: 'in', type: 'ctl' }];
  }
  if (def.mouse)   return [];
  if (def.comment) return [];
  if (def.key)     return [];
  if (def.recv)    return [];
  if (def.send)    return [{ name: 'in', type: 'ctl' }];
  if (def.ramp)    return [{ name: 'in', type: 'ctl' }, { name: 'ms', type: 'num', arg: 0 }];
  if (def.noise)   return [{ name: 'in', type: 'num' }, { name: 'f', type: 'num', arg: 0 }];
  if (def.clamp)   return [{ name: 'in', type: 'num' }, { name: 'a', type: 'num', arg: 0 }, { name: 'b', type: 'num', arg: 1 }];
  if (def.change)  return [{ name: 'in', type: 'ctl' }];
  if (def.hsl)     return def.args.map((a, i) => ({ name: a[0], type: a[1], arg: i }));
  if (def.time)    return [{ name: 'in', type: 'ctl' }];
  if (def.clip)    return [{ name: 'draw', type: 'draw' }, { name: 'mask', type: 'draw' }];
  if (def.map)     return [{ name: 'in', type: 'num' }, ...def.args.map((a, i) => ({ name: a[0], type: a[1], arg: i }))];
  if (def.spigot)  return [{ name: 'in', type: 'ctl' }, { name: 'open', type: 'num', arg: 0 }];
  if (def.pipe)    return [{ name: 'in', type: 'ctl' }, { name: 'ms', type: 'num', arg: 0 }];
  if (def.mode)    return [{ name: 'draw', type: 'draw' }, ...(def.args || []).map((a, i) => ({ name: a[0], type: a[1], arg: i }))];
  if (def.xform)   return [{ name: 'draw', type: 'draw' }, ...(def.args || []).map((a, i) => ({ name: a[0], type: a[1], arg: i }))];
  if (def.layer) {
    const n = clamp(Math.round(coerceNum(argRaw(node, 1), 4)), 1, 12);
    return Array.from({ length: n }, (_, i) => ({ name: 'd' + (i + 1), type: 'draw' }));
  }
  if (def.sink) {
    return [
      { name: 'draw', type: 'draw' },
      { name: 'w', type: 'num', arg: 0 },
      { name: 'h', type: 'num', arg: 1 },
    ];
  }
  return def.args.map((a, i) => ({ name: a[0], type: a[1], arg: i }));
}

export function outTypeOf(node) {
  const def = TYPES[node.type];
  return def ? def.out : null;
}

// the values a sel node matches against (its typed arguments)
export function selArgs(node) {
  const a = (node.tokens || []).slice(1);
  return a.length ? a : ['0'];
}

// does an incoming value equal a sel match token? (numeric tokens compare as numbers)
export function selMatch(token, value) {
  const s = String(token);
  if (/^-?\d*\.?\d+$/.test(s)) return coerceNum(value, NaN) === parseFloat(s);
  return String(value) === s;
}

// outlet spec list: [{name, type, mode?}] — most nodes have one, trigger/mouse/sel have several
export function outletsOf(node) {
  const def = TYPES[node.type];
  if (!def) return [];
  if (def.sel) {
    return [
      ...selArgs(node).map(v => ({ name: String(v), type: 'ctl' })),
      { name: 'rest', type: 'ctl' },
    ];
  }
  if (def.trigger) {
    const letters = (node.tokens || []).slice(1).filter(x => x === 'b' || x === 'v');
    const list = letters.length ? letters : ['v', 'v'];
    return list.map(l => ({ name: l === 'b' ? 'bang' : 'value', type: 'ctl', mode: l }));
  }
  if (def.mouse) {
    return [{ name: 'x', type: 'num' }, { name: 'y', type: 'num' }, { name: 'btn', type: 'num' }];
  }
  if (def.time) {
    return [{ name: 'h', type: 'num' }, { name: 'm', type: 'num' }, { name: 's', type: 'num' }];
  }
  if (def.moses) {
    return [{ name: '< thr', type: 'num' }, { name: '≥ thr', type: 'num' }];
  }
  return def.out ? [{ name: 'out', type: def.out }] : [];
}

// short arg-name hint for autocomplete (e.g. "x y w h fill stroke sw")
export function argHint(type) {
  const def = TYPES[type];
  if (!def?.args?.length) return '';
  return def.args.map(a => a[0]).join(' ');
}

// can a cable go from outlet type -> inlet type? (draw only into draw, control only into control)
export function typesMatch(fromType, toType) {
  if (!fromType || !toType) return false;
  return (fromType === 'draw') === (toType === 'draw');
}

// ADD menu categories
export const CATEGORIES = [
  ['UI',     ['bng', 'number', 'string', 'toggle', 'hslider', 'vslider', 'mouse', 'key', 'comment']],
  ['CTRL',   ['loadbang', 'metro', 'until', 'counter', 'random', 'noise', 'sin', 'cos', 'ramp', 't', 'sel', 'spigot', 'pipe', 'map', 'clamp', 'change', 'hsl', 'time', '+', '-', '*', '/', '>', '<', '==', '>=', 'moses']],
  ['DRAW',   ['bg', 'gradient', 'rect', 'circle', 'ellipse', 'line', 'text', 'polygon', 'image', 'webcam', 'feedback', 'stamp', 'tile', 'mirror', 'clip', 'rotate', 'scale', 'translate', 'alpha', 'blend', 'shadow', 'dash', 'threshold', 'posterize', 'dither', 'pixelate', 'duotone', 'blur', 'invert', 'grayscale', 'contrast', 'brightness', 'hue']],
  ['SYSTEM', ['layer', 'canvas', 'send', 'receive']],
];

// help texts: desc + use + inlets [name, type, desc] + args note + outlet
export const HELP = {
  bng: {
    short: 'bang trigger',
    desc: 'Bang button. Sends a bang message that makes other nodes act — the heartbeat of a patch.',
